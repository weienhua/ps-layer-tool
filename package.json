{
  "name": "layer-tool-cep",
  "version": "1.0.0",
  "description": "Photoshop CEP 图层处理工具插件",
  "scripts": {
    "build": "npm run build:jsx && npm run build:panel",
    "build:jsx": "webpack --config webpack.config.jsx.js",
    "build:jsx:debug": "webpack --config webpack.config.jsx.js --mode=development",
    "build:panel": "webpack --mode=production",
    "build:panel:debug": "webpack --mode=development",
    "dev": "webpack --mode=development --watch",
    "dev:jsx": "webpack --config webpack.config.jsx.js --mode=development --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "ps-extendscript-types": "^1.0.2",
    "rimraf": "^5.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "~4.9.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "keywords": [
    "photoshop",
    "cep",
    "extendscript",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "cep-shim": "^4.5.12",
    "extendscript-es5-shim": "^0.3.1"
  }
}
